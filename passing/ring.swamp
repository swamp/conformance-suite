//  **Wheel** implements a circular buffer with "silent" overwriting semantics


#[test]
fn create() {
    ring: Ring<Int; 8> 
    assert(ring.is_empty(), "should be empty")
    assert(ring.capacity() == 8, "capacity should be 8")
}

#[test]
fn push() {
    mut ring: Ring<Int; 8> 

    assert(ring.is_empty(), "should be empty")
    ring.enqueue(10)
    assert(ring.len() == 1, "should be one in length")
    assert(ring[0] == 10, "element 0 should be 10")

    ring.enqueue(20)
    assert(ring.len() == 2, "should be 2")
    assert(ring[1] == 20, "element 1 should be 20")
}


#[test]
fn init_and_push() {
    mut ring: Ring<Int; 8> = [1, 2, 3]

    assert(ring.capacity() == 8, "capacity should be 8")
    assert(ring.len() == 3, "len should be 3")
    assert(ring[0] == 1, "element 0 should be 1")
    assert(ring[1] == 2, "element 1 should be 2")
    assert(ring[2] == 3, "element 2 should be 3")
    assert(!ring.is_empty(), "should not be empty")

    ring.enqueue(4)
    assert(ring.len() == 4, "len should be 4")
    assert(ring[3] == 4, "element 3 should be 4")
}

#[test]
fn push_overwrite_when_full() {
    mut ring: Ring<Int; 4> 

    ring.enqueue(10)
    ring.enqueue(20)
    ring.enqueue(30)
    ring.enqueue(40)
    assert(ring.len() == 4, "ring should be full")
    assert(ring[0] == 10, "element 0 should be 10")
    assert(ring[1] == 20, "element 1 should be 20")
    assert(ring[2] == 30, "element 2 should be 30")
    assert(ring[3] == 40, "element 3 should be 40")

    // Push more elements - should overwrite from the first index
    ring.enqueue(50)
    assert(ring.len() == 4, "ring should still be at capacity")
    assert(ring[0] == 20, 'element 0 should 20 but got {ring[0]}')
    assert(ring[1] == 30, "element 1 should be 30")

    ring.enqueue(60)
    assert(ring[0] == 30, "element 0 should be 30")
    assert(ring[1] == 40, "element 1 should be 40")
    assert(ring[2] == 50, "element 2 should be 50")

    ring.enqueue(70)
    assert(ring[2] == 60, "element 2 should be 60")
}

#[test]
fn for_loop() {
    ring: Ring<Int; 8> = [1, 2, 3, 4, 5]

    assert(ring.len() == 5, "len should be 5")
    mut sum = 0
    for val in ring {
        sum += val
    }
    assert(sum == 15, "sum should be 15")
}

#[test]
fn for_loop_index() {
    ring: Ring<Int; 8> = [10, 20, 30]

    assert(ring.capacity() == 8, "capacity should be 8")
    assert(ring.len() == 3, "len should be 3")
    mut sum = 0
    mut index = 0
    for i, val in ring {
        assert(i == index, "index should match")
        sum += val
        index += 1
    }
    assert(sum == 60, "sum should be 60")
}

struct Point {
    x: Int
    y: Int
}

impl Point {
    fn eq(self, other: Point) -> Bool {
        .x == other.x && .y == other.y
    }
}

#[test]
fn ring_with_structs() {
    mut ring: Ring<Point; 4> = [{x: 1, y: 2}, {x: 3, y: 4}]

    assert(ring.len() == 2, "len should be 2")
    assert(ring[0].eq( {x: 1, y: 2}), "first point should be (1, 2)")
    assert(ring[1].eq( {x: 3, y: 4}), "second point should be (3, 4)")

    ring.enqueue({x: 5, y: 6})
    ring.enqueue({x: 7, y: 8})
    assert(ring.len() == 4, "ring should be full")

    // Overwrite when full
    ring.enqueue({x: 9, y: 10})
    assert(ring.len() == 4, "ring should still be at capacity")
    assert(ring[0].eq( {x: 3, y: 4}), "cursor should have moved")
}
